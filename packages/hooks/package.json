{
  "name": "@inferface/hooks",
  "version": "1.0.0-alpha.3",
  "description": "Headless React hooks for streaming AI interfaces",
  "keywords": ["react", "ai", "streaming", "llm", "hooks", "genai"],
  "homepage": "https://inferface.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/hivemindunit/inferface.git",
    "directory": "packages/hooks"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.x",
    "@testing-library/react": "^16.x",
    "@testing-library/user-event": "^14.x",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.x",
    "@vitest/coverage-v8": "^2.x",
    "jsdom": "^25.x",
    "msw": "^2.x",
    "react": "^18.x",
    "react-dom": "^18.x",
    "tsup": "^8.x",
    "typescript": "^5.x",
    "vitest": "^2.x"
  }
}
