{
  "name": "@inferface/components",
  "version": "1.0.0-alpha.1",
  "description": "React components for streaming AI interfaces",
  "keywords": ["react", "components", "ai", "streaming", "chat", "ui"],
  "homepage": "https://inferface.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/hivemindunit/inferface.git",
    "directory": "packages/components"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.mjs",
      "require": "./dist/lib/utils.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@inferface/hooks": "workspace:*",
    "clsx": "^2.x",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "tailwind-merge": "^2.x"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.x",
    "@testing-library/react": "^16.x",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.x",
    "@vitest/coverage-v8": "^2.x",
    "jsdom": "^25.x",
    "react": "^18.x",
    "react-dom": "^18.x",
    "tsup": "^8.x",
    "typescript": "^5.x",
    "vitest": "^2.x"
  }
}
